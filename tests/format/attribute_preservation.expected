/// format

@compiler c_include "stdio.h"
@compiler c_flag "-lm"

import std::mem

[export] import std::map::Map

[atomic]
let global_counter: i32 = 0

[extern] const errno: i32

struct Foo {
    [atomic]
    counter: i32
    [extern "bar_field"]
    bar: i32
    name: str
}

[alive]
def helper() {
    println("alive")
}

[extern "my_func"]
[exits]
def die() {}

def main() {
    println("test")
}
